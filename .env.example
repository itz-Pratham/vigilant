# Environment variables for vigilant
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub Personal Access Token
# Needs: Contents (R/W), Pull requests (R/W), Issues (R/W), Workflows (R/W)
# Create at: https://github.com/settings/tokens?type=beta
VIGILANT_GITHUB_TOKEN=

# ── AI Provider (at least one required) ───────────────────────────────────────

# Google Gemini — recommended (free tier at https://aistudio.google.com)
VIGILANT_GEMINI_KEY=

# Groq — fast, free tier (https://console.groq.com)
VIGILANT_GROQ_KEY=

# OpenAI — GPT-4 (https://platform.openai.com)
VIGILANT_OPENAI_KEY=

# Ollama — fully local, no key needed. Set the base URL if running locally.
VIGILANT_OLLAMA_URL=
